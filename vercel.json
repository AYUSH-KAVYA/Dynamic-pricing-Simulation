{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/app.js",
            "dest": "public/app.js"
        },
        {
            "src": "/style.css",
            "dest": "public/style.css"
        },
        {
            "src": "/(.*\\.js)",
            "dest": "public/$1"
        },
        {
            "src": "/(.*\\.css)",
            "dest": "public/$1"
        },
        {
            "src": "/",
            "dest": "public/index.html"
        }
    ]
}